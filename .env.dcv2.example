# Copy this to .env.dcv2 and fill in your credentials.
# This file is safe to commit; .env.dcv2 is gitignored.
#
# INTENDED TO RUN ON A SEPARATE DELTA SUB-ACCOUNT (its own capital/API keys),
# as an independent container parallel to the other bots. Do NOT point this at
# an account already running another bot -- separate capital means they can
# never collide on position ownership.

# --- Credentials (the SUB-ACCOUNT's own API key/secret -- NOT the main account) ---
DELTA_API_KEY=your_sub_account_api_key_here
DELTA_API_SECRET=your_sub_account_api_secret_here

# --- Exchange ---
DELTA_TESTNET=false
DELTA_REGION=india
DELTA_SYMBOL=BTCUSD

# --- Strategy: DCv2 (5m synthetic Heikin Ashi) ---
# Donchian(20) touch + open==low/high confirm, EMA(50)/EMA(200) STATE-based hunt
# gate; fixed signal-range SL, EMA-reversal + two-stage TRAIL exits. Sells options
# as the vehicle: BUY signal -> SELL PUT, SELL signal -> SELL CALL, near the target
# premium, with a 70% premium-decay TP, a 17:25 daily square-off, a 17:30 rollover
# while the trade is still open, and a Friday-flat before the weekend.
# Best backtest (5m, 25 lots, fri-flat, 70% TP): +$1,056 net / 6mo (531 legs,
# 46.3% WR). See dcv2_backtest_6mo_v2.xlsx.
DELTA_STRATEGY=dcv2
DELTA_OPTIONS_MODE=true
DELTA_TARGET_PREMIUM=900
# 70% premium-decay TP: buy the sold option back at 30% of entry (e.g. 900 -> 270).
DELTA_TAKE_PROFIT_PCT=70

# --- DCv2 indicator + behavior settings ---
DELTA_DCV2_DC_PERIOD=20
DELTA_DCV2_EMA_TREND_LENGTH=50
DELTA_DCV2_EMA_LONG_LENGTH=200
# ASAP intracandle ENTRY + SL: sell the option the instant REAL price breaks the
# signal-range trigger, and buy it back the instant price touches the fixed range
# SL -- without waiting for the 5m close. TRAIL + the EMA-reversal exit stay
# CLOSED-BAR (evaluated only when the 5m candle closes). Set false to run strictly
# closed-bar (exactly matches the backtest).
DELTA_DCV2_INTRACANDLE_ENABLED=true
# Poll the sold option's mark this often (seconds) for the 70% decay TP.
DELTA_DCV2_TP_POLL_SECONDS=15
# Flatten the whole trade at Friday's 17:25 square-off (no short option carried
# across the weekend). The winning config; backtested best of the weekend modes.
DELTA_DCV2_WEEKEND_FLAT=true
# Re-sell a fresh ~target-premium option at 17:30 while the directional trade is
# still open (daily rollover Mon-Thu; the strategy's SL/trail carries across).
DELTA_DCV2_ROLLOVER_ENABLED=true

# --- Weekend block: no NEW entries Sat/Sun (also drives the Friday-flat). ---
DELTA_SKIP_WEEKDAYS=Sat,Sun

# --- Day boundary: trade "day" starts 17:30 IST (Delta options settlement). ---
# Square-off 17:25 (5 min before the new day); entries resume 17:30.
DELTA_DAY_START_HOUR=17
DELTA_DAY_START_MINUTE=30
DELTA_SQUARE_OFF_HOUR=17
DELTA_SQUARE_OFF_MINUTE=25
DELTA_ENTRY_RESUME_HOUR=17
DELTA_ENTRY_RESUME_MINUTE=30

# --- Warmup (need >=200 5m bars for EMA200 to be ready; 3 days = 864 bars) ---
DELTA_WARMUP_CANDLES=200
DELTA_WARMUP_DAYS=3

# --- Sizing --------------------------------------------------------------------
# This engine has NEVER traded live. Start at 1 LOT, run it for a few days, and
# reconcile live fills (entry/rollover/TP/SL timing) against the backtest BEFORE
# scaling. Target size once verified: 25 (the backtested config). Set to 25 only
# after the 1-lot smoke test looks right.
DELTA_OPTION_CONTRACTS=1

# --- State file (own sub-account, but keep this path distinct from any other bot's) ---
DELTA_STATE_FILE=state/dcv2_pos.json

# --- Telegram (reuse the SAME token + chat ID as your other bots -- bot_label
#     tags every message so you can tell this bot's signals apart) ---
DELTA_TELEGRAM_TOKEN=same_token_as_your_other_bots
DELTA_TELEGRAM_CHAT_ID=same_chat_id_as_your_other_bots
DELTA_BOT_LABEL=DCv2

# --- Operational ---
DELTA_CLOSE_ON_SHUTDOWN=false
DELTA_LOG_LEVEL=INFO

# Diagnostic: per-closed-candle strategy-state snapshot (HA/EMA/Donchian/
# open==low/touched/pending/pos), ~288 lines/day. On to reconstruct why a
# signal did/did not fire from live data. Leave false unless investigating.
DELTA_DCV2_DEBUG_STATE=false
