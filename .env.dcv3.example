# Copy this to .env.dcv3 and fill in your credentials.
# This file is safe to commit; .env.dcv3 is gitignored.
#
# INTENDED TO RUN ON A SEPARATE DELTA SUB-ACCOUNT (its own capital/API keys),
# as an independent container parallel to the other bots (incl. dcv2bot). Do
# NOT point this at an account already running another bot -- separate
# capital means they can never collide on position ownership.

# --- Credentials (the SUB-ACCOUNT's own API key/secret -- NOT the main account) ---
DELTA_API_KEY=your_sub_account_api_key_here
DELTA_API_SECRET=your_sub_account_api_secret_here

# --- Exchange ---
DELTA_TESTNET=false
DELTA_REGION=india
DELTA_SYMBOL=BTCUSD

# --- Strategy: DCv3 = DCv2's signal logic, but BUYS options instead of
# selling them (the mirror of dcv2bot). BUY signal -> buy CALL, SELL signal ->
# buy PUT. Max loss per trade is capped at the premium paid -- no margin/
# leverage concept, unlike selling. Exits: strategy SL, EMA-reversal/TRAIL,
# or the rally take-profit below. "24/7" per request: NO weekend skip, trades
# roll straight through Sat/Sun (see DELTA_SKIP_WEEKDAYS and
# DELTA_DCV2_WEEKEND_FLAT below).
# Best backtest (5m, buy, 500 premium, 100% TP, 24/7, 25 lots, 1 MONTH only):
# +$206.82 net (109 legs, 48.6% WR). See dcv2_BUY500_1mo_24x7.xlsx.
# HONESTY: only 1 month of backtest history (dcv2bot's sell config has 6
# months) -- treat live results with extra caution for the first few weeks.
DELTA_STRATEGY=dcv3
DELTA_OPTIONS_MODE=true
DELTA_OPTION_SIDE=buy
DELTA_TARGET_PREMIUM=500
# Rally take-profit: close when the BOUGHT option's premium rises this %
# (100 -> the option must DOUBLE, e.g. entry 500 -> TP 1000).
DELTA_TAKE_PROFIT_PCT=100

# --- DCv2 indicator + behavior settings (shared field names with dcv2bot --
#     each bot's own env file sets them independently) ---
DELTA_DCV2_DC_PERIOD=20
DELTA_DCV2_EMA_TREND_LENGTH=50
DELTA_DCV2_EMA_LONG_LENGTH=200
# ASAP intracandle ENTRY + SL (TRAIL/EMA-reversal stay closed-bar). Set false
# to run strictly closed-bar (exactly matches the backtest).
DELTA_DCV2_INTRACANDLE_ENABLED=true
# Poll the bought option's mark this often (seconds) for the rally TP. The TP
# check is a point-in-time snapshot (not a continuous "touched" scan like the
# backtest's candle-high check), so a brief wick above target between two
# polls can be missed entirely -- tightened from 15s to 5s (2026-07-19) to
# shrink that window after a live miss was observed. Trade-off: more mark-
# price API calls (well within rate limits at 1 symbol / 5s).
DELTA_DCV2_TP_POLL_SECONDS=5
# 24/7: do NOT flatten before the weekend (a bought option's max loss is
# already capped at the premium paid, so holding through Sat/Sun doesn't add
# the gap risk that made this unattractive for the SELL side).
DELTA_DCV2_WEEKEND_FLAT=false
# Re-buy a fresh ~target-premium option at 17:30 while the directional trade
# is still open (daily rollover).
DELTA_DCV2_ROLLOVER_ENABLED=true
# Remove the 17:25-17:30 settlement gap: close AND immediately re-buy the
# still-open directional trade's option in the SAME 17:25 event instead of
# waiting 5 minutes. false = today's live behavior (unchanged) if left unset.
DELTA_DCV2_CONTINUOUS_ROLL=false

# --- Weekend block: EMPTY = 24/7, no Sat/Sun entry block (per request). ---
DELTA_SKIP_WEEKDAYS=

# --- Day boundary: trade "day" starts 17:30 IST (Delta options settlement). ---
# Square-off 17:25 (5 min before the new day); entries resume 17:30. This
# daily close/rollover is UNCHANGED from dcv2bot -- only the weekend handling
# differs for the "24/7" config.
DELTA_DAY_START_HOUR=17
DELTA_DAY_START_MINUTE=30
DELTA_SQUARE_OFF_HOUR=17
DELTA_SQUARE_OFF_MINUTE=25
DELTA_ENTRY_RESUME_HOUR=17
DELTA_ENTRY_RESUME_MINUTE=30

# --- Warmup (need >=200 5m bars for EMA200 to be ready; 3 days = 864 bars) ---
DELTA_WARMUP_CANDLES=200
DELTA_WARMUP_DAYS=3

# --- Sizing --------------------------------------------------------------------
# This engine has NEVER traded live, and BUYING is new execution code (not
# just a config flip like dcv2's variants) -- consider a short 1-lot smoke
# test before trusting fills, even though 25 lots was the explicit target size.
DELTA_OPTION_CONTRACTS=25

# --- State file (own sub-account, but keep this path distinct from any other bot's) ---
DELTA_STATE_FILE=state/dcv3_pos.json

# --- Telegram (reuse the SAME token + chat ID as your other bots -- bot_label
#     tags every message so you can tell this bot's signals apart) ---
DELTA_TELEGRAM_TOKEN=same_token_as_your_other_bots
DELTA_TELEGRAM_CHAT_ID=same_chat_id_as_your_other_bots
DELTA_BOT_LABEL=DCv3

# --- Operational ---
DELTA_CLOSE_ON_SHUTDOWN=false
DELTA_LOG_LEVEL=INFO
# Diagnostic: log a full strategy-state snapshot on every closed 5m candle
# (HA/EMA/Donchian/open==low/touched/pending/pos). ~288 lines/day. Turn on to
# capture WHY a signal did/didn't fire, minute-by-minute, from the bot's own
# live data. Leave false unless investigating.
DELTA_DCV2_DEBUG_STATE=false
