# Delta Exchange API credentials (required for live trading)
DELTA_API_KEY=your_api_key_here
DELTA_API_SECRET=your_api_secret_here

# Environment: true = testnet (default, recommended), false = live real funds
DELTA_TESTNET=true

# Market. india -> BTCUSD (product_id 27); global -> BTCUSDT (product_id 139).
# product_id is resolved automatically at startup if left unset.
DELTA_REGION=india
DELTA_SYMBOL=BTCUSD
# DELTA_PRODUCT_ID=27

# Strategy / sizing
DELTA_CONTRACTS=1            # 1 contract = 0.001 BTC
DELTA_LEVERAGE=10
DELTA_ATR_PERIOD=10
DELTA_ST_MULTIPLIER=3
DELTA_EMA_LENGTH=50          # 50-EMA of high and of low (entry filters)
DELTA_USE_CLOSE=true         # compare bar close (false = high/low) against the levels
DELTA_RESOLUTION=1m
DELTA_WARMUP_CANDLES=200
DELTA_WARMUP_DAYS=3          # also pull >= this many days so prev-day levels exist

# Custom day boundary (previous-day open/close) and forced square-off
DELTA_DAY_TZ=Asia/Kolkata
DELTA_DAY_START_HOUR=5       # a new custom "day" begins at 05:30 in DELTA_DAY_TZ
DELTA_DAY_START_MINUTE=30
DELTA_SQUARE_OFF_HOUR=17     # force-exit any open position at 17:25 in DELTA_DAY_TZ
DELTA_SQUARE_OFF_MINUTE=25
DELTA_ENTRY_RESUME_HOUR=17   # entries resume at 17:30 (after options settlement); flat in the 17:25–17:30 window
DELTA_ENTRY_RESUME_MINUTE=30

# Options execution mode (set to true to trade options instead of futures).
# Delta uses single-letter C/P (Call/Put), NOT the NSE CE/PE convention.
# When enabled, BUY signal -> sell ITM PUT, SELL signal -> sell ITM CALL.
# Exit (SL or EOD) uses the same BTC-price logic but closes the option position.
# DELTA_LEVERAGE is ignored in options mode (options use dynamic per-strike margin),
# and positions are sized in contracts/lots (DELTA_OPTION_CONTRACTS), not BTC quantity.
# IMPORTANT: validate on testnet (DELTA_TESTNET=true) for at least one trading day
# before setting DELTA_TESTNET=false to go live with real funds.
DELTA_OPTIONS_MODE=true
DELTA_OPTION_OFFSET=400          # points from price: PUT strike = price+400, CALL strike = price-400
DELTA_OPTION_CONTRACTS=1         # number of option lots to sell per signal
DELTA_OPTION_STRIKE_INTERVAL=200 # fallback rounding only; bot snaps to the nearest LISTED strike from the live chain
DELTA_OPTION_EXPIRY_CUTOFF_HOUR=17  # IST hour; if past this, use next-day expiry (options settle 17:30 IST)
DELTA_OPTION_MIN_AVAILABLE_BALANCE=0  # skip selling if available wallet balance below this (0 = no check)
# DELTA_OPTION_MARGIN_ASSET=USD       # wallet asset to check balance for (blank = max across wallets)

# Telegram notifications (optional; leave blank to log-only)
DELTA_TELEGRAM_TOKEN=
DELTA_TELEGRAM_CHAT_ID=

# Operational
DELTA_CLOSE_ON_SHUTDOWN=false
DELTA_DAILY_SUMMARY_HOUR_UTC=0
DELTA_LOG_LEVEL=INFO
