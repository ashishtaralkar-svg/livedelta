# Copy this to .env.heikinashi and fill in your credentials.
# This file is safe to commit; .env.heikinashi is gitignored.
#
# INTENDED TO RUN ON A SEPARATE DELTA SUB-ACCOUNT (its own capital/API keys),
# as an independent container parallel to the main-account bot(s). Do NOT
# point this at the same account as deltabot/revbreakbot.

# --- Credentials (the SUB-ACCOUNT's own API key/secret -- NOT the main account) ---
DELTA_API_KEY=your_sub_account_api_key_here
DELTA_API_SECRET=your_sub_account_api_secret_here

# --- Exchange ---
DELTA_TESTNET=false
DELTA_REGION=india
DELTA_SYMBOL=BTCUSD

# --- Strategy ---
DELTA_STRATEGY=heikin_ashi
DELTA_OPTIONS_MODE=true
# Best validated config this session (30-day backtest, ASAP entry/SL/TRAIL,
# per-trade option resolution, 1-minute closed candles): 717 trades, 35.4% win
# rate, net +$922.02 -- see heikin_ashi_30d_asap_trail.xlsx.
DELTA_TARGET_PREMIUM=900
DELTA_ATR_PERIOD=10
# Supertrend(10,2): validated to beat (10,3) on both 1-month (+10%) and
# 4-month (+18%) 1m backtests.
DELTA_ST_MULTIPLIER=2.0
DELTA_EMA_LENGTH=50
DELTA_EMA200_LENGTH=200

# --- Day boundary: trade "day" starts 17:30 IST (Delta options settlement). ---
# Square-off 17:25 (5 min before the new day); entries resume 17:30.
DELTA_DAY_START_HOUR=17
DELTA_DAY_START_MINUTE=30
DELTA_SQUARE_OFF_HOUR=17
DELTA_SQUARE_OFF_MINUTE=25
DELTA_ENTRY_RESUME_HOUR=17
DELTA_ENTRY_RESUME_MINUTE=30

# --- Sizing ---
DELTA_OPTION_CONTRACTS=25

# --- State file (own sub-account, but keep this path distinct from any other bot's) ---
DELTA_STATE_FILE=state/heikin_ashi_pos.json

# --- Telegram (reuse the SAME token + chat ID already configured on EC2 for
#     the main bot -- bot_label tags every message so you can tell this bot's
#     signals apart from any other bot posting to the same chat) ---
DELTA_TELEGRAM_TOKEN=same_token_as_ec2_main_env
DELTA_TELEGRAM_CHAT_ID=same_chat_id_as_ec2_main_env
DELTA_BOT_LABEL=HeikinAshi

# --- Operational ---
DELTA_CLOSE_ON_SHUTDOWN=false
DELTA_LOG_LEVEL=INFO
