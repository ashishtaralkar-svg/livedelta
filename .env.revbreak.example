# Copy this to .env.revbreak and fill in your credentials.
# This file is safe to commit; .env.revbreak is gitignored.

# --- Credentials (same account as deltabot, or a sub-account) ---
DELTA_API_KEY=your_api_key_here
DELTA_API_SECRET=your_api_secret_here

# --- Exchange ---
DELTA_TESTNET=false
DELTA_REGION=india
DELTA_SYMBOL=BTCUSD

# --- Strategy ---
DELTA_STRATEGY=revbreak
DELTA_OPTIONS_MODE=true
DELTA_TARGET_PREMIUM=900
DELTA_TAKE_PROFIT_PCT=70
DELTA_REVBREAK_GATE=open
# Pin RevBreak's Supertrend multiplier to its own validated value (3.0),
# independent of the code default (which is 2.0 for HeikinAshi).
DELTA_ST_MULTIPLIER=3.0
# Best 4-month config: ST filter OFF + re-entry block OFF (NET +$4,823 vs +$2,714).
DELTA_REVBREAK_ST_FILTER=false
DELTA_REVBREAK_REENTRY_BLOCK=false

# --- Day boundary: trade "day" starts 17:30 IST (Delta options settlement). ---
# Best 4-month config used the 17:30 boundary (+$607 vs the 05:30 boundary).
# Square-off stays 17:25 (5 min before the new day); entries resume 17:30.
DELTA_DAY_START_HOUR=17
DELTA_DAY_START_MINUTE=30

# --- Sizing ---
DELTA_OPTION_CONTRACTS=50
DELTA_SKIP_WEEKDAYS=Sat

# --- State file (MUST differ from deltabot's state file to prevent reconcile conflict) ---
DELTA_STATE_FILE=state/revbreak_pos.json

# --- Telegram (can reuse same bot token; messages will show contract name to distinguish) ---
DELTA_TELEGRAM_TOKEN=your_bot_token_here
DELTA_TELEGRAM_CHAT_ID=your_chat_id_here

# --- Operational ---
DELTA_CLOSE_ON_SHUTDOWN=false
DELTA_LOG_LEVEL=INFO
