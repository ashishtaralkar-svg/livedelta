# Copy this to .env.dcv2sim and fill in the API key.
# This file is safe to commit; .env.dcv2sim is gitignored.
#
# SHADOW / PAPER bot: runs the EXACT DCv2 strategy (same as dcv2bot) but places
# NO real orders -- it only posts [DCv2-SIM] signals to Telegram so you can
# compare the model against the live dcv2bot in real time. It reads market data
# and option marks for realistic premiums, but PaperExecutor can never trade.
# Runs CLOSED-BAR (intracandle OFF) to mirror the backtest exactly, so the
# live-vs-model divergence (e.g. an intracandle entry the model takes on the
# next close) is visible in the two Telegram streams.
#
# It needs NO dedicated sub-account -- since it never trades, you can safely
# reuse ANY of your existing read-capable Delta API keys (e.g. dcv2bot's). It
# only READS the chain/marks; it never opens a position.

# --- Credentials (any valid read-capable key; PaperExecutor never trades) ---
DELTA_API_KEY=any_read_capable_api_key_here
DELTA_API_SECRET=any_read_capable_api_secret_here

# --- Exchange ---
DELTA_TESTNET=false
DELTA_REGION=india
DELTA_SYMBOL=BTCUSD

# --- Strategy: DCv2, but PAPER (no real orders) ---
DELTA_STRATEGY=dcv2
DELTA_OPTIONS_MODE=true
DELTA_PAPER_MODE=true
DELTA_OPTION_SIDE=sell
DELTA_TARGET_PREMIUM=900
DELTA_TAKE_PROFIT_PCT=70

# --- DCv2 settings: MATCH dcv2bot's live config EXACTLY, except intracandle
#     OFF so the shadow runs closed-bar like the backtest. ---
DELTA_DCV2_DC_PERIOD=20
DELTA_DCV2_EMA_TREND_LENGTH=50
DELTA_DCV2_EMA_LONG_LENGTH=200
# Closed-bar (mirror the backtest). This is the whole point of the shadow --
# it makes the intracandle-vs-closed-bar divergence visible.
DELTA_DCV2_INTRACANDLE_ENABLED=false
DELTA_DCV2_TP_POLL_SECONDS=15
DELTA_DCV2_WEEKEND_FLAT=true
DELTA_DCV2_ROLLOVER_ENABLED=true

# --- Weekend block: match dcv2bot (Sat/Sun) ---
DELTA_SKIP_WEEKDAYS=Sat,Sun

# --- Day boundary (match dcv2bot) ---
DELTA_DAY_START_HOUR=17
DELTA_DAY_START_MINUTE=30
DELTA_SQUARE_OFF_HOUR=17
DELTA_SQUARE_OFF_MINUTE=25
DELTA_ENTRY_RESUME_HOUR=17
DELTA_ENTRY_RESUME_MINUTE=30

# --- Warmup ---
DELTA_WARMUP_CANDLES=200
DELTA_WARMUP_DAYS=3

# --- Sizing: match dcv2bot so the notional/P&L in the signals is comparable
#     (no real capital is used -- it's paper). ---
DELTA_OPTION_CONTRACTS=25

# --- State file (distinct path; barely used since paper reconcile starts flat) ---
DELTA_STATE_FILE=state/dcv2sim_pos.json

# --- Telegram: SAME token + chat as your live bots; the label makes it
#     separable. [DCv2-SIM] = the model; [DCv2] = the live bot. ---
DELTA_TELEGRAM_TOKEN=same_token_as_your_other_bots
DELTA_TELEGRAM_CHAT_ID=same_chat_id_as_your_other_bots
DELTA_BOT_LABEL=DCv2-SIM

# --- Operational ---
DELTA_CLOSE_ON_SHUTDOWN=false
DELTA_LOG_LEVEL=INFO
