# Copy this to .env.dchannel and fill in your credentials.
# This file is safe to commit; .env.dchannel is gitignored.
#
# INTENDED TO RUN ON A SEPARATE DELTA SUB-ACCOUNT (its own capital/API keys),
# as an independent container parallel to the main-account bot(s). Do NOT
# point this at the same account as revbreakbot -- separate capital means the
# two can never collide on position ownership.

# --- Credentials (the SUB-ACCOUNT's own API key/secret -- NOT the main account) ---
DELTA_API_KEY=your_sub_account_api_key_here
DELTA_API_SECRET=your_sub_account_api_secret_here

# --- Exchange ---
DELTA_TESTNET=false
DELTA_REGION=india
DELTA_SYMBOL=BTCUSD

# --- Strategy: DchannelStrategy (5m synthetic Heikin Ashi) ---
DELTA_STRATEGY=dchannel
DELTA_OPTIONS_MODE=true
# Best validated config (5m, WR OFF, EMA200 price filter, sell ~1000 premium,
# 70% premium-decay TP): 6-month backtest +$545.66 (750 trades, 41.3% WR),
# 1-month +$121.07. See dchannel_ema200_wrOFF_5m_6mo.xlsx. Runs closed-bar only
# (no intracandle), matching the backtest.
DELTA_TARGET_PREMIUM=1000
# Premium-decay take-profit: exit when the sold option's mark falls by this %
# (70 -> buy back at 30% of entry, e.g. entry ~1000 -> TP ~300).
DELTA_TAKE_PROFIT_PCT=70

# --- Dchannel indicator settings ---
DELTA_DCHANNEL_DC_PERIOD=20
DELTA_DCHANNEL_WR_PERIOD=14
DELTA_DCHANNEL_WR_LEVEL=80
DELTA_DCHANNEL_EMA_LENGTH=200
# 0 = price-vs-EMA trend filter (the winning config). >0 switches to an
# EMA-vs-SMA(this length) cross filter -- backtested worse, leave at 0.
DELTA_DCHANNEL_MA_LENGTH=0
# Williams %R gate OFF: validated to beat ON (5m 6mo: +$546 vs +$389). With it
# off, both directions hunt on every Donchian touch (no oversold/overbought gate).
DELTA_DCHANNEL_WR_ENABLED=false
# Poll the sold option's mark this often (seconds) for the premium-decay TP.
DELTA_DCHANNEL_TP_POLL_SECONDS=15

# --- Day boundary: trade "day" starts 17:30 IST (Delta options settlement). ---
# Square-off 17:25 (5 min before the new day); entries resume 17:30.
DELTA_DAY_START_HOUR=17
DELTA_DAY_START_MINUTE=30
DELTA_SQUARE_OFF_HOUR=17
DELTA_SQUARE_OFF_MINUTE=25
DELTA_ENTRY_RESUME_HOUR=17
DELTA_ENTRY_RESUME_MINUTE=30

# --- Warmup (need >=200 5m bars for EMA200 to be ready; 3 days = 864 bars) ---
DELTA_WARMUP_CANDLES=200
DELTA_WARMUP_DAYS=3

# --- Sizing: START AT 1 LOT. This strategy has never traded live -- run it at
#     1 lot for a week and reconcile live fills vs backtest before scaling. ---
DELTA_OPTION_CONTRACTS=1

# --- State file (own sub-account, but keep this path distinct from any other bot's) ---
DELTA_STATE_FILE=state/dchannel_pos.json

# --- Telegram (reuse the SAME token + chat ID as your other bots -- bot_label
#     tags every message so you can tell this bot's signals apart) ---
DELTA_TELEGRAM_TOKEN=same_token_as_your_other_bots
DELTA_TELEGRAM_CHAT_ID=same_chat_id_as_your_other_bots
DELTA_BOT_LABEL=Dchannel

# --- Operational ---
DELTA_CLOSE_ON_SHUTDOWN=false
DELTA_LOG_LEVEL=INFO
